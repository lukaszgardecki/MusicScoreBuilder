<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.Group?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:id="scrollPane"
            fitToWidth="true"
            fitToHeight="true"
            pannable="false"
            fx:controller="org.example.musicscorebuilder.PageAreaController"
>
    <HBox fx:id="pageContainer" spacing="40" alignment="CENTER">
        <Pane fx:id="page" styleClass="page-a4">
            <Pane fx:id="contentArea"/>
        </Pane>
    </HBox>
</ScrollPane>

