<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<ToolBar
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="org.example.musicscorebuilder.controller.ToolbarController"
    styleClass="main-toolbar"
>
    <Separator />
    <Button fx:id="modeButton" styleClass="toolbar-btn" text="IN" onAction="#toggleMode"/>
    <Separator />
    <Button styleClass="toolbar-btn" text="64" />
    <Button styleClass="toolbar-btn" text="32" />
    <Button styleClass="toolbar-btn" text="16" />
    <Button styleClass="toolbar-btn" text="8" />
    <Button styleClass="toolbar-btn" text="4" />
    <Button styleClass="toolbar-btn" text="2" />
    <Button styleClass="toolbar-btn" text="1" />
    <Separator />
    <Button styleClass="toolbar-btn" text="p1" />
    <Button styleClass="toolbar-btn" text="p2" />
    <Button styleClass="toolbar-btn" text="p3" />
    <Separator />
    <Button fx:id="addMeasure" styleClass="toolbar-btn" text="+" onAction="#addMeasure"/>
    <Button fx:id="removeMeasure" styleClass="toolbar-btn" text="-" onAction="#removeMeasure"/>
</ToolBar>
